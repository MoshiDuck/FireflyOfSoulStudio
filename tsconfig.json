{
  "compilerOptions": {
    "target": "es2016",
    "module": "es2015",
    "outDir": "public/scripts",
    "rootDir": "src/scripts",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "src/scripts/**/*"
  ],
  "exclude": [
    "node_modules",
    "public"
  ]
}