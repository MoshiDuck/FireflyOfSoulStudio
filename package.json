{
  "name": "fireflyofsoulstudio",
  "version": "1.0.0",
  "scripts": {
    "build": "npm run build:css && npm run build:js",
    "build:css": "sass src/styles/main.scss public/styles/main.css",
    "build:js": "tsc",
    "dev": "npm run build && firebase serve",
    "deploy": "npm run build && firebase deploy --only hosting",
    "clean": "rm -rf public/scripts/*"
  },
  "devDependencies": {
    "sass": "^1.32.0",
    "typescript": "^4.9.0"
  },
  "dependencies": {
    "firebase-functions": "^6.4.0",
    "gsap": "^3.13.0"
  }
}